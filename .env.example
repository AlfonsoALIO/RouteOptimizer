# Copy to `.env` in this directory and fill in values. Never commit `.env`.

# Django (required)
DJANGO_SECRET_KEY=
# Local dev: DJANGO_DEBUG=true
DJANGO_DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# SQL Server (required for core/main.py)
SQLSERVER_SERVER=localhost
SQLSERVER_PORT=1443
SQLSERVER_DATABASE=stg_Production
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=
